# ── Postgres ──────────────────────────────────────────────────────────────────
# asyncpg-compatible DSN.  Used by /graph (AGE) and /live (PostGIS) directly.
# vLLM and pgvector URLs are configured inside Llama Stack's run.yaml, not here.
POSTGRES_DSN=postgresql://sim:sim@localhost:5432/sim

# ── Llama Stack ───────────────────────────────────────────────────────────────
# All inference, embedding, and vector/RAG calls go through the Llama Stack
# server.  This is the only URL app code knows about for LLM/vector concerns.
LLAMA_STACK_BASE_URL=http://localhost:8321

# ── Model IDs (must match what is registered in Llama Stack's run.yaml) ───────
GENERATION_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
EMBEDDING_MODEL_ID=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Runtime mode ──────────────────────────────────────────────────────────────
# Set to true to swap in FakeLlamaStackClient so the stack runs without a GPU
# or a live Llama Stack server (used in CI and local dev without hardware).
USE_FAKE_LLAMA_STACK=false
